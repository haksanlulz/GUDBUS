# --- Core (required) -------------------------------------------------------
DISCORD_TOKEN=your_bot_token_here
DATABASE_URL=sqlite+aiosqlite:///data/gurps_bot.db

# --- Command sync (optional) ----------------------------------------------
# Set DEV_GUILD_ID to auto-register commands to one guild on startup (instant,
# for testing) when SYNC_ON_START is truthy. Leave both blank to sync manually
# in Discord with /sync (owner-only).
DEV_GUILD_ID=
SYNC_ON_START=

# --- Legal / about (/legal, /about) ---------------------------------------
# The SJG Online Policy requires the game aid be attributed to its author.
BOT_AUTHOR_LEGAL_NAME=
# Optional links shown in /legal and /about.
BOT_INVITE_URL=
BOT_SUPPORT_URL=

# --- Donation links (/support, /donate) -----------------------------------
# All optional. Only configured https links are shown; with none set, the
# command shows a "best support is sharing the bot" message. The bot never
# handles payments; these just link out to the platforms.
KOFI_URL=
BUYMEACOFFEE_URL=
PATREON_URL=
GITHUB_SPONSORS_URL=
PAYPAL_URL=
LIBERAPAY_URL=
# Optional: override the thank-you blurb at the top of the /support embed.
SUPPORT_MESSAGE=
